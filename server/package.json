{
  "name": "opd-backend",
  "version": "1.0.0",
  "description": "Backend for OPD system",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm --experimental-specifier-resolution=node index.ts",
    "db:init": "node --loader ts-node/esm --experimental-specifier-resolution=node db/init-db.ts",
    "db:seed": "node --loader ts-node/esm --experimental-specifier-resolution=node db/seed-users.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
